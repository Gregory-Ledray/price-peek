{
  "manifest_version": 3,
  "name": "Price Peek",
  "version": "0.0.1",
  "description": "Finds pricing for the same products across retailers.",
  "permissions": ["sidePanel", "tabs", "activeTab"],
  "host_permissions": ["*://*.google.com/*", "https://*.amazon.com/*", "https://*.walmart.com/*", "https://*.target.com/*"],
  "action": {
    "default_title": "Open Price Peek"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
