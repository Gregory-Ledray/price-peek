{
  "manifest_version": 3,
  "name": "Price Peek",
  "version": "0.0.1",
  "description": "Finds pricing for a product across retailers",
  "permissions": ["sidePanel", "storage", "activeTab"],
  "host_permissions": ["https://*.amazon.com/*", "https://*.target.com/*", "https://*.menards.com/*"],
  "action": {
    "default_title": "Open Price Peek"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
